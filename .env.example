# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hall_sync
DB_SSL=false
DB_SSL_CA_PATH=config/aiven-ca.pem

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_MIN_COUNT=7
# Destructive retention remains dry-run unless explicitly enabled by the scheduler.
BACKUP_RETENTION_APPLY=false
# Separate, pre-created empty database used only for restore drills.
RESTORE_DB_NAME=hall_sync_restore_test
RESTORE_DB_HOST=localhost
RESTORE_DB_PORT=3306
RESTORE_DB_USER=root
RESTORE_DB_PASSWORD=replace-with-restore-only-password
RESTORE_DB_SSL=false
RESTORE_DB_SSL_CA_PATH=config/aiven-ca.pem
# Must be set only for an intentional isolated restore execution.
RESTORE_DRILL_CONFIRM=false

# API Configuration
API_PREFIX=/api
TRUST_PROXY_HOPS=0

# Login abuse protection (failed attempts only)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_IP_FAILURES=20
LOGIN_RATE_LIMIT_MAX_ACCOUNT_FAILURES=8

# CORS Settings
CORS_ORIGIN=http://localhost:8080

# Logging
LOG_LEVEL=info
ERROR_MONITORING_DSN=replace-with-provider-dsn
UPTIME_MONITOR_HEALTH_URL=https://api.yourdomain.com/api/health
UPTIME_MONITOR_FRONTEND_URL=https://app.yourdomain.com
OPS_ALERT_RECIPIENT=ops@yourdomain.com

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# Email Configuration (Optional - Booking works without email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_ENABLED=false
SMTP_SECURE=false
SMTP_FROM=invoices@yourdomain.com

# Manual Hall Sync subscription payments
UPI_ID=your-business-upi-id@bank
FRONTEND_URL=http://localhost:8080
SUBSCRIPTION_GRACE_DAYS=7
SUBSCRIPTION_MAINTENANCE_APPLY=false
# Daily job records skipped reminders unless explicitly enabled with working SMTP.
SUBSCRIPTION_REMINDERS_SEND=false

# Administrative maintenance scripts
SUPER_ADMIN_EMAIL=owner@hallsync.in
SUPER_ADMIN_PASSWORD=replace-with-a-long-random-password
