# Hall Sync backend production environment for VPS
# Copy to /etc/hallsync-api.env on the server. Do not commit real values.

NODE_ENV=production
PORT=5000
API_PREFIX=/api
TRUST_PROXY_HOPS=1

# Exact HTTPS frontend origin. No wildcard.
CORS_ORIGIN=https://hallsync.in
FRONTEND_URL=https://hallsync.in
PUBLIC_APP_URL=https://hallsync.in
PUBLIC_API_BASE_URL=https://api.hallsync.in

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_NAME=replace-with-db-name
DB_SSL=false
DB_SSL_CA_PATH=
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Auth
JWT_SECRET=replace-with-new-random-minimum-32-character-secret
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# Login abuse protection
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_IP_FAILURES=20
LOGIN_RATE_LIMIT_MAX_ACCOUNT_FAILURES=8

# Logging and monitoring
LOG_LEVEL=info
ERROR_MONITORING_DSN=replace-with-provider-dsn
UPTIME_MONITOR_HEALTH_URL=https://api.hallsync.in/api/health
UPTIME_MONITOR_FRONTEND_URL=https://hallsync.in
OPS_ALERT_RECIPIENT=ops@hallsync.in

# SMTP
SMTP_ENABLED=true
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-secret
SMTP_SECURE=false
SMTP_FROM=no-reply@hallsync.in

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Local fallback for public/non-sensitive images when Cloudinary is not configured.
# Sensitive payment proofs still require Cloudinary.
LOCAL_UPLOAD_ROOT=/var/www/hallsync/uploads

# Manual Hall Sync subscription payments
UPI_ID=replace-with-business-upi-id
SUBSCRIPTION_GRACE_DAYS=7
SUBSCRIPTION_MAINTENANCE_APPLY=false
SUBSCRIPTION_REMINDERS_SEND=false

# Backups
BACKUP_DIR=/var/www/hallsync/backups/database
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_MIN_COUNT=7
BACKUP_RETENTION_APPLY=false

# Restore drill target must be separate/non-production
RESTORE_DB_NAME=hallsync_restore_drill
RESTORE_DB_HOST=127.0.0.1
RESTORE_DB_PORT=3306
RESTORE_DB_USER=replace-with-restore-only-user
RESTORE_DB_PASSWORD=replace-with-restore-only-password
RESTORE_DB_SSL=false
RESTORE_DRILL_CONFIRM=false
