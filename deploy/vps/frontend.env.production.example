# Hall Sync frontend production build environment
# Copy to hall-sync-calendar-view/.env.production before running npm run build.

VITE_API_BASE_URL=https://api.hallsync.in/api
VITE_NODE_ENV=production
VITE_APP_NAME=HallSync
VITE_APP_VERSION=1.0.0
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true
VITE_DEBUG_MODE=false
VITE_ERROR_MONITORING_DSN=replace-with-provider-dsn
