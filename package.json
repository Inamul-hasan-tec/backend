{
  "name": "hall-sync-backend",
  "version": "1.0.0",
  "description": "Hall Sync - Marriage Hall Booking System Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "watch": "nodemon --exec ts-node src/server.ts",
    "test": "ts-node tests/run.ts",
    "migrate:platform": "node scripts/run_platform_migrations.js",
    "staging:audit": "node scripts/audit_staging_schema.js",
    "production:audit": "HALL_SYNC_PRODUCTION_TARGET=true node scripts/audit_staging_schema.js",
    "production:readiness": "node scripts/production_readiness_audit.js",
    "production:deployment-audit": "node scripts/audit_deployment_config.js",
    "production:smtp:verify": "node scripts/verify_smtp_config.js",
    "production:launch-gate": "node scripts/production_launch_gate.js",
    "production:backup": "node scripts/backup_database.js",
    "production:backup:verify": "node scripts/verify_database_backup.js",
    "production:backup:retention": "node scripts/prune_database_backups.js",
    "production:backup:scheduled": "node scripts/run_scheduled_backup.js",
    "production:restore:drill": "node scripts/restore_database_drill.js",
    "production:subscriptions:daily": "node scripts/run_subscription_maintenance.js",
    "production:migrate": "node scripts/run_production_migration_window.js",
    "acceptance:provision": "node scripts/provision_acceptance_environment.js",
    "acceptance:production": "node scripts/production_acceptance_probe.js"
  },
  "keywords": [
    "hall-booking",
    "marriage-hall",
    "booking-system",
    "typescript",
    "express"
  ],
  "author": "Hall Sync Team",
  "license": "MIT",
  "dependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.3",
    "@types/pdfkit": "^0.13.4",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "multiparty": "^4.2.3",
    "mysql2": "^3.6.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.15.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/multiparty": "^4.2.1",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2"
  }
}
